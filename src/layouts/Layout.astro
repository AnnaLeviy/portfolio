---
import "../styles/global.css";

interface Props {
  title?: string;
}

const { title = "Аня — дизайн интерфейсов" } = Astro.props;
const base = import.meta.env.BASE_URL.replace(/\/?$/, "/");
---

<!doctype html>
<html lang="ru">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&family=Roboto+Condensed:wght@400;500&display=swap" rel="stylesheet" />
    <title>{title}</title>
    <slot name="head" />
  </head>
  <body class="bg-[#f3f3f8] text-[#212326] antialiased">
    <div class="mx-auto max-w-[1440px] px-10 pt-5 pb-[60px]">
      <header class="sticky top-5 z-50 rounded-[20px] bg-white/80 backdrop-blur-[20px]">
        <nav class="flex h-[74px] items-center justify-between px-10">
          <a href={base} class="shrink-0">
            <img src={`${base}logo.svg`} alt="Логотип" width="55" height="54" />
          </a>
          <div class="flex items-center gap-10 font-['Inter'] text-lg font-medium">
            <a href={base} class="text-black">Главная</a>
            <a href="#cases" class="flex items-center gap-1 text-black">
              Кейсы
              <svg width="12" height="12" viewBox="0 0 12 12" fill="none"><path d="M3 5L6 8L9 5" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/></svg>
            </a>
            <a href="#contacts" class="text-black">Контакты</a>
          </div>
          <div class="w-[55px] shrink-0"></div>
        </nav>
      </header>
      <slot />
    </div>
  </body>
</html>
