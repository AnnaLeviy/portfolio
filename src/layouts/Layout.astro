---
import "../styles/global.css";

interface Props {
  title?: string;
}

const { title = "Портфолио" } = Astro.props;
---

<!doctype html>
<html lang="ru">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{title}</title>
    <slot name="head" />
  </head>
  <body class="bg-white text-neutral-900 antialiased">
    <header class="border-b border-neutral-200">
      <nav class="mx-auto flex max-w-5xl items-center justify-between px-6 py-4">
        <a href={`${import.meta.env.BASE_URL}`} class="text-lg font-semibold">Портфолио</a>
        <div class="flex gap-6 text-sm text-neutral-600">
          <a href={`${import.meta.env.BASE_URL}projects/brand-identity/`} class="hover:text-neutral-900">Айдентика</a>
          <a href={`${import.meta.env.BASE_URL}projects/mobile-app/`} class="hover:text-neutral-900">Приложение</a>
        </div>
      </nav>
    </header>
    <slot />
  </body>
</html>
