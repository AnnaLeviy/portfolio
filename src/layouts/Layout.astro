---
import "../styles/global.css";

interface Props {
  title?: string;
}

const { title = "Аня — дизайн интерфейсов" } = Astro.props;
const base = import.meta.env.BASE_URL.replace(/\/?$/, "/");
---

<!doctype html>
<html lang="ru">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{title}</title>
    <slot name="head" />
  </head>
  <body class="bg-white text-neutral-900 antialiased">
    <header class="sticky top-0 z-50 bg-white/80 backdrop-blur-md">
      <nav class="mx-auto flex max-w-6xl items-center justify-between px-6 py-5">
        <a href={base}>
          <img src={`${base}logo.svg`} alt="Логотип" width="40" height="38" />
        </a>
        <div class="flex gap-8 text-sm font-medium">
          <a href={base} class="text-neutral-900">Главная</a>
          <a href="#cases" class="text-neutral-400 hover:text-neutral-900 transition">Кейсы</a>
          <a href="#contacts" class="text-neutral-400 hover:text-neutral-900 transition">Контакты</a>
        </div>
      </nav>
    </header>
    <slot />
  </body>
</html>
