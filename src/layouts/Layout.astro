---
import "../styles/global.css";

interface Props {
  title?: string;
}

const { title = "Аня — дизайн интерфейсов" } = Astro.props;
const base = import.meta.env.BASE_URL.replace(/\/?$/, "/");
---

<!doctype html>
<html lang="ru">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&family=Roboto+Condensed:wght@400;500&display=swap" rel="stylesheet" />
    <title>{title}</title>
    <slot name="head" />
  </head>
  <body class="bg-[#f3f3f8] text-[#212326] antialiased">
    <div class="mx-auto max-w-[1440px] px-10 pt-5 pb-[60px]">
      <header class="sticky top-5 z-50 rounded-[20px] bg-white/80 backdrop-blur-[20px]">
        <nav class="flex h-[74px] items-center justify-between px-10">
          <a href={base} class="shrink-0">
            <img src={`${base}logo.svg`} alt="Логотип" width="55" height="54" />
          </a>
          <div class="flex items-center gap-10 font-['Inter'] text-lg font-medium">
            <a href={base} class="text-black">Главная</a>
            <div class="relative group">
              <button class="flex items-center gap-1 text-black cursor-pointer">
                Кейсы
                <svg class="transition-transform group-hover:rotate-180" width="12" height="12" viewBox="0 0 12 12" fill="none"><path d="M3 5L6 8L9 5" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/></svg>
              </button>
              <div class="invisible opacity-0 group-hover:visible group-hover:opacity-100 transition-all duration-200 absolute top-full left-1/2 -translate-x-1/2 pt-3">
                <div class="bg-white rounded-[16px] shadow-[0_8px_32px_rgba(0,0,0,0.12)] p-2 min-w-[200px]">
                  <a href={`${base}projects/bringo/`} class="block px-4 py-3 rounded-[12px] text-[15px] text-[#212326] hover:bg-[#f3f3f8] transition">Bringo</a>
                  <a href={`${base}projects/epay/`} class="block px-4 py-3 rounded-[12px] text-[15px] text-[#212326] hover:bg-[#f3f3f8] transition">ePay</a>
                  <a href={`${base}projects/skyeng/`} class="block px-4 py-3 rounded-[12px] text-[15px] text-[#212326] hover:bg-[#f3f3f8] transition">Skyeng</a>
                </div>
              </div>
            </div>
            <a href={`${base}#contacts`} class="text-black">Контакты</a>
          </div>
          <div class="w-[55px] shrink-0"></div>
        </nav>
      </header>
      <slot />
    </div>
  </body>
</html>
