---
import Layout from "../layouts/Layout.astro";

const base = import.meta.env.BASE_URL.replace(/\/?$/, "/");
const projects = [
  {
    slug: "brand-identity",
    title: "Айдентика бренда",
    description: "Разработка визуальной идентичности для стартапа в сфере образования",
    tags: ["Брендинг", "Логотип", "Гайдлайн"],
  },
  {
    slug: "mobile-app",
    title: "Мобильное приложение",
    description: "Дизайн интерфейса приложения для планирования задач",
    tags: ["UI/UX", "Mobile", "Figma"],
  },
  {
    slug: "web-redesign",
    title: "Редизайн сайта",
    description: "Обновление визуала и структуры корпоративного сайта",
    tags: ["Web", "UI/UX", "Прототип"],
  },
];
---

<Layout>
  <main class="mx-auto max-w-5xl px-6">
    <section class="py-16">
      <h1 class="text-3xl font-bold">Привет, я дизайнер</h1>
      <p class="mt-3 max-w-xl text-neutral-600">
        Делаю айдентику, интерфейсы и всё, что между ними. Ниже — избранные проекты.
      </p>
    </section>

    <section class="grid gap-8 pb-20 sm:grid-cols-2 lg:grid-cols-3">
      {projects.map((p) => (
        <a
          href={`${base}projects/${p.slug}/`}
          class="group block rounded-xl border border-neutral-200 p-5 transition hover:border-neutral-400"
        >
          <div class="mb-4 aspect-[4/3] rounded-lg bg-neutral-100" />
          <h2 class="font-semibold group-hover:underline">{p.title}</h2>
          <p class="mt-1 text-sm text-neutral-500">{p.description}</p>
          <div class="mt-3 flex flex-wrap gap-2">
            {p.tags.map((tag) => (
              <span class="rounded-full bg-neutral-100 px-2.5 py-0.5 text-xs text-neutral-600">
                {tag}
              </span>
            ))}
          </div>
        </a>
      ))}
    </section>
  </main>
</Layout>
