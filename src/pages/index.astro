---
import Layout from "../layouts/Layout.astro";

const base = import.meta.env.BASE_URL.replace(/\/?$/, "/");

const companies = [
  { name: "Skillbox" },
  { name: "Skyeng" },
  { name: "Magnit" },
  { name: "Bringo" },
  { name: "ePayments" },
];

const cases = [
  {
    slug: "bringo",
    title: "Bringo",
    description: "Сервис по расширенному поиску и подбору контрагентов для бизнесов на рынке UK",
  },
  {
    slug: "epay",
    title: "ePay",
    description: "Мобильное финтех приложение для самозанятых и тех, кто выплачивает зарплаты",
  },
  {
    slug: "skyeng",
    title: "Skyeng",
    description: "Сервис по расширенному поиску и подбору контрагентов для бизнесов на рынке UK",
  },
];
---

<Layout>
  <div class="flex flex-col gap-[100px] items-center mt-[100px]">

    <!-- Hero -->
    <section class="flex flex-col items-center gap-10 w-[670px] max-w-full text-center">
      <h1 class="font-['Roboto_Condensed'] font-medium text-[64px] leading-[70px] text-[#212326]">
        Я Аня —  дизайню интерфейсы. Это моё портфолио.
      </h1>
      <a
        href="#"
        class="inline-flex items-center justify-center bg-[#1b1c1d] text-white font-['Inter'] font-medium text-[17px] leading-8 tracking-[0.34px] rounded-[24px] px-8 py-5 hover:bg-neutral-700 transition"
      >
        Резюме PDF
      </a>
    </section>

    <!-- Hero image placeholder -->
    <div class="w-full aspect-[16/9] rounded-[40px] bg-[#2f8afc] max-w-4xl"></div>

    <!-- Experience -->
    <section class="w-full flex flex-col gap-10">
      <div class="flex gap-3 items-start w-full">
        <div class="w-[331px] shrink-0 flex items-start pt-3">
          <div class="flex items-center gap-3">
            <div class="w-[102px] h-[2px] bg-gradient-to-r from-[#00c1ff] via-[#2f8afc] to-[#62bd67]"></div>
            <span class="font-['Roboto_Condensed'] text-[16px] uppercase leading-8 whitespace-nowrap text-[#212326]">Опыт работы</span>
          </div>
        </div>
        <p class="flex-1 font-['Inter'] font-medium text-[38px] leading-[50px] text-[#212326]">
          Я успела поработать с отличными командами и многому научиться. Спасибо этим компаниям за доверие, вызовы и вдохновение.
        </p>
      </div>

      <div class="flex gap-3 w-full">
        {companies.map((c) => (
          <div class="flex-1 bg-white rounded-[80px] h-[238px] flex flex-col items-center justify-end gap-5 pb-[58px]">
            <!-- Placeholder: company logo -->
            <div class="w-[70px] h-[70px] rounded-full bg-neutral-100"></div>
            <span class="font-['Inter'] font-medium text-[20px] leading-6 text-[#212326]">{c.name}</span>
          </div>
        ))}
      </div>
    </section>

    <!-- Divider -->
    <div class="w-full h-px bg-neutral-200"></div>

    <!-- Cases -->
    <section id="cases" class="w-full flex flex-col gap-[54px]">
      <h2 class="font-['Roboto_Condensed'] font-medium text-[64px] leading-[70px] text-center text-[#212326]">
        Продуктовые кейсы
      </h2>

      <div class="flex flex-col gap-[54px]">
        <!-- Bringo -->
        <a href={`${base}projects/bringo/`} class="group flex gap-3 items-end w-full">
          <div class="w-[903px] h-[501px] rounded-[120px] bg-[#2f8afc] overflow-hidden shrink-0">
            <!-- Placeholder: Bringo cover -->
          </div>
          <div class="bg-white rounded-[50px] w-[445px] h-[501px] shrink-0 flex flex-col justify-between p-10">
            <div class="flex flex-col gap-5">
              <h3 class="font-['Inter'] font-semibold text-[44px] leading-[52px] text-[#212326]">Bringo</h3>
              <p class="font-['Inter'] font-medium text-[15px] leading-[22px] text-[#212326]">{cases[0].description}</p>
            </div>
            <div class="bg-[#1b1c1d] rounded-[24px] px-8 py-5 self-start group-hover:bg-neutral-700 transition">
              <span class="font-['Inter'] font-medium text-[17px] leading-8 tracking-[0.34px] text-white">Подробнее</span>
            </div>
          </div>
        </a>

        <!-- ePay -->
        <a href={`${base}projects/epay/`} class="group flex gap-3 items-center w-full">
          <div class="bg-white rounded-[50px] w-[445px] h-[501px] shrink-0 flex flex-col justify-between p-10">
            <div class="flex flex-col gap-5">
              <h3 class="font-['Inter'] font-semibold text-[44px] leading-[52px] text-[#212326]">ePay</h3>
              <p class="font-['Inter'] font-medium text-[15px] leading-[22px] text-[#212326]">{cases[1].description}</p>
            </div>
            <div class="bg-[#1b1c1d] rounded-[24px] px-8 py-5 self-start group-hover:bg-neutral-700 transition">
              <span class="font-['Inter'] font-medium text-[17px] leading-8 tracking-[0.34px] text-white">Подробнее</span>
            </div>
          </div>
          <div class="h-[501px] rounded-[120px] bg-gradient-to-b from-[#f22d40] to-[#ff475e] overflow-hidden shrink-0 w-[446px]">
            <!-- Placeholder: ePay cover 1 -->
          </div>
          <div class="h-[501px] rounded-[120px] bg-gradient-to-b from-[#1f1fda] to-[#0f0fa9] overflow-hidden shrink-0 w-[445px]">
            <!-- Placeholder: ePay cover 2 -->
          </div>
        </a>

        <!-- Skyeng -->
        <a href={`${base}projects/skyeng/`} class="group flex gap-3 items-end w-full">
          <div class="w-[903px] h-[500px] rounded-[120px] bg-[#2f89fc] overflow-hidden shrink-0">
            <!-- Placeholder: Skyeng cover -->
          </div>
          <div class="bg-white rounded-[50px] w-[445px] h-[501px] shrink-0 flex flex-col justify-between p-10">
            <div class="flex flex-col gap-5">
              <h3 class="font-['Inter'] font-semibold text-[44px] leading-[52px] text-[#212326]">Skyeng</h3>
              <p class="font-['Inter'] font-medium text-[15px] leading-[22px] text-[#212326]">{cases[2].description}</p>
            </div>
            <div class="bg-[#1b1c1d] rounded-[24px] px-8 py-5 self-start group-hover:bg-neutral-700 transition">
              <span class="font-['Inter'] font-medium text-[17px] leading-8 tracking-[0.34px] text-white">Подробнее</span>
            </div>
          </div>
        </a>
      </div>
    </section>

    <!-- Divider -->
    <div class="w-full h-px bg-neutral-200"></div>

    <!-- About -->
    <section class="w-full flex flex-col gap-[54px]">
      <h2 class="font-['Roboto_Condensed'] font-medium text-[64px] leading-[70px] text-center text-[#212326]">
        Обо мне
      </h2>

      <div class="flex flex-col gap-10">
        <div class="flex gap-3 items-start w-full">
          <div class="w-[331px] shrink-0 flex items-start pt-3">
            <div class="flex items-center gap-3">
              <div class="w-[102px] h-[2px] bg-gradient-to-r from-[#00c1ff] via-[#2f8afc] to-[#62bd67]"></div>
              <span class="font-['Roboto_Condensed'] text-[16px] uppercase leading-8 whitespace-nowrap text-[#212326]">Давайте знакомиться</span>
            </div>
          </div>
          <p class="flex-1 font-['Inter'] font-medium text-[38px] leading-[50px] text-[#212326]">
            Вне работы рисую мемы: красками и в 3D. Жила три года на Пхукете — научилась есть острое и смотреть на всё проще.
          </p>
        </div>

        <div class="flex gap-3 w-full">
          <!-- Placeholder: 4 about images -->
          <div class="flex-1 h-[320px] rounded-[100px] bg-white overflow-hidden"></div>
          <div class="flex-1 h-[320px] rounded-[100px] bg-white overflow-hidden"></div>
          <div class="flex-1 h-[320px] rounded-[100px] bg-white overflow-hidden"></div>
          <div class="flex-1 h-[320px] rounded-[100px] bg-white overflow-hidden"></div>
        </div>
      </div>

      <!-- Contacts -->
      <div id="contacts" class="bg-white rounded-[50px] w-full flex flex-col items-center gap-[54px] pt-10 pb-[60px] px-10">
        <div class="font-['Roboto_Condensed'] font-medium text-[54px] leading-[64px] text-center text-[#212326]">
          <p>Вы долистали до конца!</p>
          <p>Осталось только написать</p>
        </div>

        <div class="flex flex-col items-center gap-5">
          <!-- Placeholder: Telegram icon -->
          <div class="w-16 h-16 rounded-full bg-[#2AABEE] flex items-center justify-center">
            <svg width="28" height="24" viewBox="0 0 28 24" fill="white"><path d="M2.73 10.42L25.13 1.88c1.03-.37 1.93.25 1.59 1.83l-3.81 17.96c-.28 1.26-.97 1.57-1.97 0.98l-5.44-4.01-2.63 2.53c-.29.29-.53.53-1.09.53l.39-5.56 10.11-9.13c.44-.39-.1-.61-.68-.22L9.33 16.24l-5.36-1.68c-1.17-.37-1.19-1.17.24-1.73z"/></svg>
          </div>
          <a
            href="https://t.me/Anna_Levitina"
            class="font-['Inter'] font-medium text-[20px] leading-6 text-[#212326] hover:underline"
            target="_blank"
            rel="noopener"
          >
            @Anna_Levitina
          </a>
        </div>

        <div class="flex flex-col items-center gap-5">
          <!-- Placeholder: Google/Gmail icon -->
          <div class="w-16 h-16 flex items-center justify-center">
            <span class="text-4xl font-bold text-[#4285F4]">G</span>
          </div>
          <a
            href="mailto:anna.levi.designer@gmail.com"
            class="font-['Inter'] font-medium text-[20px] leading-6 text-[#212326] hover:underline"
          >
            anna.levi.designer@gmail.com
          </a>
        </div>
      </div>
    </section>

    <!-- Bottom logo -->
    <footer>
      <img src={`${base}logo.svg`} alt="Логотип" width="81" height="80" />
    </footer>
  </div>
</Layout>
