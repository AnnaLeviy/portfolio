---
import Layout from "../layouts/Layout.astro";

const base = import.meta.env.BASE_URL.replace(/\/?$/, "/");
---

<Layout title="Страница не найдена">
  <main class="mx-auto flex max-w-5xl flex-col items-center justify-center px-6 py-32 text-center">
    <p class="text-6xl font-bold text-neutral-300">404</p>
    <h1 class="mt-4 text-xl font-semibold">Страница не найдена</h1>
    <a href={base} class="mt-6 text-sm text-neutral-500 hover:text-neutral-900">&larr; На главную</a>
  </main>
</Layout>
