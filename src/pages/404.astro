---
import Layout from "../layouts/Layout.astro";

const base = import.meta.env.BASE_URL.replace(/\/?$/, "/");
---

<Layout title="Страница не найдена">
  <div class="flex flex-col items-center justify-center gap-6 py-32 text-center">
    <p class="font-['Roboto_Condensed'] font-medium text-[120px] md:text-[180px] leading-none text-neutral-200">404</p>
    <h1 class="font-['Inter'] font-medium text-[28px] md:text-[38px] leading-[40px] md:leading-[50px] text-[#212326]">
      Страница не найдена
    </h1>
    <a
      href={base}
      class="inline-flex items-center justify-center bg-[#1b1c1d] text-white font-['Inter'] font-medium text-[17px] leading-8 tracking-[0.34px] rounded-[24px] px-8 py-5 hover:bg-neutral-700 transition"
    >
      На главную
    </a>
  </div>
</Layout>
