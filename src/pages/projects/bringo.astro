---
import Layout from "../../layouts/Layout.astro";

const base = import.meta.env.BASE_URL.replace(/\/?$/, "/");
---

<Layout title="Bringo — кейс">
  <div class="flex flex-col gap-[60px] md:gap-[100px] items-center mt-[60px] md:mt-[100px]">

    <!-- Hero -->
    <section class="flex flex-col items-center gap-10 max-w-[675px] text-center">
      <h1 class="font-['Roboto_Condensed'] font-medium text-[48px] md:text-[64px] leading-[56px] md:leading-[70px] text-[#212326]">
        Bringo. B2B-продукт с данными о компаниях, финансах и связях
      </h1>
      <a
        href="https://bringo.co.uk"
        target="_blank"
        rel="noopener"
        class="font-['Inter'] font-medium text-[17px] leading-10 text-[#212326] hover:underline"
      >
        bringo.co.uk
      </a>
      <div class="flex gap-3">
        <span class="font-['Inter'] font-medium text-[16px] leading-8 border border-[#212326] rounded-[24px] px-5 py-4">Web</span>
        <span class="font-['Inter'] font-medium text-[16px] leading-8 border border-[#212326] rounded-[24px] px-5 py-4">Mobile app</span>
        <span class="font-['Inter'] font-medium text-[16px] leading-8 border border-[#212326] rounded-[24px] px-5 py-4">b2b</span>
      </div>
    </section>

    <!-- Cover -->
    <div class="w-full h-[500px] md:h-[800px] rounded-[40px] md:rounded-[60px] bg-[#2f8afc] overflow-hidden">
      <!-- Placeholder: Bringo cover image -->
    </div>

    <!-- Позиционирование -->
    <section class="w-full flex flex-col gap-10">
      <div class="flex flex-col md:flex-row gap-3 items-start w-full">
        <div class="md:w-[331px] shrink-0 flex items-start pt-3">
          <div class="flex items-center gap-3">
            <div class="w-[102px] h-[2px] bg-gradient-to-r from-[#00c1ff] via-[#2f8afc] to-[#62bd67]"></div>
            <span class="font-['Roboto_Condensed'] text-[16px] uppercase leading-8 whitespace-nowrap text-[#212326]">Позиционирование</span>
          </div>
        </div>
        <div class="flex-1 flex flex-col gap-10">
          <h2 class="font-['Inter'] font-semibold text-[28px] md:text-[38px] leading-[36px] md:leading-[54px] text-[#212326]">
            Как это начиналось?
          </h2>
          <div class="flex flex-col gap-10 font-['Inter'] font-medium text-[15px] leading-[22px] text-[#212326]">
            <p>Bringo задумывался как инструмент для проверки контрагентов на рынке Великобритании. Команда хотела собрать данные Companies House, финансовую отчётность и связи между директорами в одном месте.</p>
            <p>Первая версия продукта была сфокусирована на узкой аудитории — compliance-специалистах. Но в процессе исследования стало понятно, что потребность шире: менеджеры по продажам, аналитики и даже инвесторы искали удобный способ находить и оценивать компании.</p>
            <p>Мы выбрали массовый рынок и начали строить продукт, который объединяет поиск, фильтрацию и аналитику в едином интерфейсе.</p>
          </div>
        </div>
      </div>
    </section>

    <!-- Исследования -->
    <section class="w-full flex flex-col gap-10">
      <div class="flex flex-col md:flex-row gap-3 items-start w-full">
        <div class="md:w-[331px] shrink-0 flex items-start pt-3">
          <div class="flex items-center gap-3">
            <div class="w-[102px] h-[2px] bg-gradient-to-r from-[#00c1ff] via-[#2f8afc] to-[#62bd67]"></div>
            <span class="font-['Roboto_Condensed'] text-[16px] uppercase leading-8 whitespace-nowrap text-[#212326]">Исследования</span>
          </div>
        </div>
        <div class="flex-1 flex flex-col gap-10">
          <h2 class="font-['Inter'] font-semibold text-[28px] md:text-[38px] leading-[36px] md:leading-[54px] text-[#212326]">
            Глубинные интервью
          </h2>
          <div class="flex flex-col gap-10 font-['Inter'] font-medium text-[15px] leading-[22px] text-[#212326]">
            <p>Провели серию глубинных интервью с потенциальными пользователями: от менеджеров по продажам до compliance-офицеров. Выяснили ключевые сценарии использования и болевые точки существующих решений.</p>
            <p>Главный инсайт — пользователям не хватает возможности быстро оценить компанию «на глаз» без погружения в десятки документов.</p>
          </div>
        </div>
      </div>
    </section>

    <!-- Инсайты -->
    <div class="w-full h-[400px] md:h-[853px] rounded-[40px] md:rounded-[60px] bg-white overflow-hidden">
      <!-- Placeholder: Insights image -->
    </div>

    <!-- Портрет пользователя -->
    <section class="w-full flex flex-col gap-10">
      <div class="flex flex-col md:flex-row gap-3 items-start w-full">
        <div class="md:w-[331px] shrink-0 flex items-start pt-3">
          <div class="flex items-center gap-3">
            <div class="w-[102px] h-[2px] bg-gradient-to-r from-[#00c1ff] via-[#2f8afc] to-[#62bd67]"></div>
            <span class="font-['Roboto_Condensed'] text-[16px] uppercase leading-8 whitespace-nowrap text-[#212326]">Исследования</span>
          </div>
        </div>
        <div class="flex-1 flex flex-col gap-10">
          <h2 class="font-['Inter'] font-semibold text-[28px] md:text-[38px] leading-[36px] md:leading-[54px] text-[#212326]">
            Портрет пользователя
          </h2>
          <div class="font-['Inter'] font-medium text-[15px] leading-[22px] text-[#212326]">
            <p class="mb-6">На основе интервью выделили четыре ключевых сегмента:</p>
            <ul class="list-disc pl-5 flex flex-col gap-3">
              <li>Sales-менеджеры — ищут новых клиентов и проверяют лиды</li>
              <li>Compliance-специалисты — проверяют контрагентов перед сделкой</li>
              <li>Аналитики — исследуют рынок и конкурентов</li>
              <li>Инвесторы — оценивают компании перед вложением</li>
            </ul>
          </div>
        </div>
      </div>
    </section>

    <!-- Divider -->
    <div class="w-full h-px bg-neutral-200"></div>

    <!-- Расширенный поиск -->
    <h2 class="font-['Roboto_Condensed'] font-medium text-[54px] md:text-[64px] leading-[64px] md:leading-[70px] text-center text-[#212326] w-full">
      Расширенный поиск
    </h2>

    <!-- Search showcase -->
    <div class="w-full h-[400px] md:h-[724px] rounded-[40px] md:rounded-[60px] bg-white overflow-hidden">
      <!-- Placeholder: Search showcase with laptop & phone mockups -->
    </div>

    <!-- Продуктовый кейс — Что было -->
    <section class="w-full flex flex-col gap-10">
      <div class="flex flex-col md:flex-row gap-3 items-start w-full">
        <div class="md:w-[331px] shrink-0 flex items-start pt-3">
          <div class="flex items-center gap-3">
            <div class="w-[102px] h-[2px] bg-gradient-to-r from-[#00c1ff] via-[#2f8afc] to-[#62bd67]"></div>
            <span class="font-['Roboto_Condensed'] text-[16px] uppercase leading-8 whitespace-nowrap text-[#212326]">Продуктовый кейс</span>
          </div>
        </div>
        <div class="flex-1 flex flex-col gap-10">
          <h2 class="font-['Inter'] font-semibold text-[28px] md:text-[38px] leading-[36px] md:leading-[54px] text-[#212326]">
            Что было
          </h2>
          <p class="font-['Inter'] font-medium text-[15px] leading-[22px] text-[#212326]">
            Старый интерфейс поиска был перегружен: длинные списки без фильтрации, отсутствие сортировки и невозможность быстро сравнить компании между собой.
          </p>
        </div>
      </div>
    </section>

    <!-- Before screenshot -->
    <div class="w-full h-[500px] md:h-[925px] rounded-[40px] md:rounded-[60px] bg-white overflow-hidden">
      <!-- Placeholder: Old search UI screenshot -->
    </div>

    <!-- Продуктовый кейс — Что я сделала -->
    <section class="w-full flex flex-col gap-10">
      <div class="flex flex-col md:flex-row gap-3 items-start w-full">
        <div class="md:w-[331px] shrink-0 flex items-start pt-3">
          <div class="flex items-center gap-3">
            <div class="w-[102px] h-[2px] bg-gradient-to-r from-[#00c1ff] via-[#2f8afc] to-[#62bd67]"></div>
            <span class="font-['Roboto_Condensed'] text-[16px] uppercase leading-8 whitespace-nowrap text-[#212326]">Продуктовый кейс</span>
          </div>
        </div>
        <div class="flex-1 flex flex-col gap-10">
          <h2 class="font-['Inter'] font-semibold text-[28px] md:text-[38px] leading-[36px] md:leading-[54px] text-[#212326]">
            Что я сделала
          </h2>
          <p class="font-['Inter'] font-medium text-[15px] leading-[22px] text-[#212326]">
            Полностью переработала экран поиска и фильтрации. Создала систему, которая позволяет гибко комбинировать параметры и мгновенно видеть результат.
          </p>
          <ul class="list-disc pl-5 flex flex-col gap-3 font-['Inter'] font-medium text-[15px] leading-[22px] text-[#212326]">
            <li>Разработала панель фильтров с группировкой по категориям</li>
            <li>Добавила сортировку и быстрый просмотр карточек компаний</li>
            <li>Сделала выгрузку результатов в CSV</li>
            <li>Адаптировала интерфейс под мобильные устройства</li>
          </ul>
        </div>
      </div>
    </section>

    <!-- After screenshot -->
    <div class="w-full h-[500px] md:h-[1042px] rounded-[40px] md:rounded-[60px] bg-white overflow-hidden">
      <!-- Placeholder: New search UI screenshot -->
    </div>

    <!-- Результаты -->
    <section class="w-full flex flex-col gap-10">
      <div class="flex flex-col md:flex-row gap-3 items-start w-full">
        <div class="md:w-[331px] shrink-0 flex items-start pt-3">
          <div class="flex items-center gap-3">
            <div class="w-[102px] h-[2px] bg-gradient-to-r from-[#00c1ff] via-[#2f8afc] to-[#62bd67]"></div>
            <span class="font-['Roboto_Condensed'] text-[16px] uppercase leading-8 whitespace-nowrap text-[#212326]">Результаты</span>
          </div>
        </div>
        <div class="flex-1 flex flex-col gap-10">
          <h2 class="font-['Inter'] font-semibold text-[28px] md:text-[38px] leading-[36px] md:leading-[54px] text-[#212326]">
            Результаты
          </h2>
          <div class="flex flex-col gap-6 font-['Inter'] font-medium text-[15px] leading-[22px] text-[#212326]">
            <p>Использование фильтров выросло в 3 раза после редизайна</p>
            <p>Выгрузка CSV увеличилась на 20%</p>
            <p>Вовлечённость пользователей выросла на 12%</p>
            <p>Более 10% пользователей стали переходить на страницы компаний из результатов поиска</p>
          </div>
        </div>
      </div>
    </section>

    <!-- Divider -->
    <div class="w-full h-px bg-neutral-200"></div>

    <!-- Ещё экраны -->
    <h2 class="font-['Roboto_Condensed'] font-medium text-[54px] md:text-[64px] leading-[64px] md:leading-[70px] text-center text-[#212326] w-full">
      Ещё экраны
    </h2>

    <!-- Company page screenshot -->
    <div class="w-full flex flex-col gap-6">
      <div class="w-full h-[500px] md:h-[1114px] rounded-[40px] md:rounded-[60px] bg-white overflow-hidden">
        <!-- Placeholder: Company page desktop -->
      </div>
      <p class="font-['Inter'] font-medium text-[15px] leading-[22px] text-[#212326] text-center">Страница компании</p>
    </div>

    <!-- Mobile company page -->
    <div class="w-full flex flex-col gap-6">
      <div class="w-full h-[500px] md:h-[1131px] rounded-[40px] md:rounded-[60px] bg-white overflow-hidden">
        <!-- Placeholder: Company page mobile app -->
      </div>
      <p class="font-['Inter'] font-medium text-[15px] leading-[22px] text-[#212326] text-center">Страница компании — мобильное приложение</p>
    </div>

    <!-- Mobile filters -->
    <div class="w-full flex flex-col gap-6">
      <div class="w-full h-[500px] md:h-[1131px] rounded-[40px] md:rounded-[60px] bg-white overflow-hidden">
        <!-- Placeholder: Filters mobile app -->
      </div>
      <p class="font-['Inter'] font-medium text-[15px] leading-[22px] text-[#212326] text-center">Фильтры — мобильное приложение</p>
    </div>

    <!-- CSV export -->
    <div class="w-full flex flex-col gap-6">
      <div class="w-full h-[500px] md:h-[1029px] rounded-[40px] md:rounded-[60px] bg-white overflow-hidden">
        <!-- Placeholder: CSV export screens -->
      </div>
      <p class="font-['Inter'] font-medium text-[15px] leading-[22px] text-[#212326] text-center">Выгрузка CSV</p>
    </div>

    <!-- Divider -->
    <div class="w-full h-px bg-neutral-200"></div>

    <!-- Другие проекты -->
    <section class="w-full flex flex-col gap-10 md:gap-[54px]">
      <h2 class="font-['Roboto_Condensed'] font-medium text-[54px] md:text-[64px] leading-[64px] md:leading-[70px] text-center text-[#212326]">
        Другие проекты
      </h2>

      <div class="flex flex-col md:flex-row gap-3 w-full">
        <a href={`${base}projects/epay/`} class="group flex-1 bg-white rounded-[50px] flex flex-col gap-10 p-10">
          <div class="flex flex-col gap-5">
            <h3 class="font-['Inter'] font-semibold text-[44px] leading-[52px] text-[#212326]">ePay</h3>
            <p class="font-['Inter'] font-medium text-[15px] leading-[22px] text-[#212326]">Мобильное финтех приложение для самозанятых</p>
          </div>
          <div class="w-full h-[240px] rounded-[30px] bg-gradient-to-b from-[#f22d40] to-[#ff475e] overflow-hidden">
            <!-- Placeholder: ePay cover -->
          </div>
          <div class="bg-[#1b1c1d] rounded-[24px] px-8 py-5 self-start group-hover:bg-neutral-700 transition">
            <span class="font-['Inter'] font-medium text-[17px] leading-8 tracking-[0.34px] text-white">Подробнее</span>
          </div>
        </a>

        <a href={`${base}projects/skyeng/`} class="group flex-1 bg-white rounded-[50px] flex flex-col gap-10 p-10">
          <div class="flex flex-col gap-5">
            <h3 class="font-['Inter'] font-semibold text-[44px] leading-[52px] text-[#212326]">Skyeng</h3>
            <p class="font-['Inter'] font-medium text-[15px] leading-[22px] text-[#212326]">Экран оплаты и выбора тарифа</p>
          </div>
          <div class="w-full h-[240px] rounded-[30px] bg-[#2f89fc] overflow-hidden">
            <!-- Placeholder: Skyeng cover -->
          </div>
          <div class="bg-[#1b1c1d] rounded-[24px] px-8 py-5 self-start group-hover:bg-neutral-700 transition">
            <span class="font-['Inter'] font-medium text-[17px] leading-8 tracking-[0.34px] text-white">Подробнее</span>
          </div>
        </a>
      </div>
    </section>

    <!-- Divider -->
    <div class="w-full h-px bg-neutral-200"></div>

    <!-- Contacts -->
    <div id="contacts" class="bg-white rounded-[50px] w-full flex flex-col items-center gap-[54px] pt-10 pb-[60px] px-10">
      <div class="font-['Roboto_Condensed'] font-medium text-[40px] md:text-[54px] leading-[50px] md:leading-[64px] text-center text-[#212326]">
        <p>Вы долистали до конца!</p>
        <p>Осталось только написать</p>
      </div>

      <div class="flex flex-col items-center gap-5">
        <div class="w-16 h-16 rounded-full bg-[#2AABEE] flex items-center justify-center">
          <svg width="28" height="24" viewBox="0 0 28 24" fill="white"><path d="M2.73 10.42L25.13 1.88c1.03-.37 1.93.25 1.59 1.83l-3.81 17.96c-.28 1.26-.97 1.57-1.97 0.98l-5.44-4.01-2.63 2.53c-.29.29-.53.53-1.09.53l.39-5.56 10.11-9.13c.44-.39-.1-.61-.68-.22L9.33 16.24l-5.36-1.68c-1.17-.37-1.19-1.17.24-1.73z"/></svg>
        </div>
        <a
          href="https://t.me/Anna_Levitina"
          class="font-['Inter'] font-medium text-[20px] leading-6 text-[#212326] hover:underline"
          target="_blank"
          rel="noopener"
        >
          @Anna_Levitina
        </a>
      </div>

      <div class="flex flex-col items-center gap-5">
        <div class="w-16 h-16 flex items-center justify-center">
          <span class="text-4xl font-bold text-[#4285F4]">G</span>
        </div>
        <a
          href="mailto:anna.levi.designer@gmail.com"
          class="font-['Inter'] font-medium text-[20px] leading-6 text-[#212326] hover:underline"
        >
          anna.levi.designer@gmail.com
        </a>
      </div>
    </div>

    <!-- Bottom logo -->
    <footer>
      <img src={`${base}logo.svg`} alt="Логотип" width="81" height="80" />
    </footer>
  </div>
</Layout>
