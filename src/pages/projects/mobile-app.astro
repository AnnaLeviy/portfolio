---
import Layout from "../../layouts/Layout.astro";

const base = import.meta.env.BASE_URL.replace(/\/?$/, "/");
---

<Layout title="Мобильное приложение">
  <main class="mx-auto max-w-3xl px-6 py-16">
    <a href={base} class="text-sm text-neutral-500 hover:text-neutral-900">&larr; Назад</a>

    <h1 class="mt-6 text-3xl font-bold">Мобильное приложение</h1>
    <p class="mt-3 text-neutral-600">
      Дизайн интерфейса приложения для планирования задач.
    </p>

    <div class="mt-10 space-y-8">
      <div class="aspect-[16/9] rounded-xl bg-neutral-100" />
      <div>
        <h2 class="text-xl font-semibold">Задача</h2>
        <p class="mt-2 text-neutral-600">Спроектировать простой и интуитивный интерфейс для ежедневного использования.</p>
      </div>
      <div class="aspect-[16/9] rounded-xl bg-neutral-100" />
      <div>
        <h2 class="text-xl font-semibold">Решение</h2>
        <p class="mt-2 text-neutral-600">Чистый UI с фокусом на быстром вводе задач, жестовая навигация и минимум экранов.</p>
      </div>
      <div class="aspect-[16/9] rounded-xl bg-neutral-100" />
    </div>
  </main>
</Layout>
